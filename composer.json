{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-bcmath": "*",
        "ext-curl": "*",
        "doctrine/dbal": "^4.3",
        "filament/filament": "^4.0",
        "guzzlehttp/guzzle": "^7.10",
        "inertiajs/inertia-laravel": "^2.0",
        "intervention/image": "^3.0",
        "laracasts/utilities": "^3.2.4",
        "laravel/framework": "^11.45",
        "laravel/sanctum": "^4.2",
        "laravel/socialite": "^5.23",
        "laravel/tinker": "^2.10",
        "laravel/ui": "^4.6",
        "laravel/vapor-cli": "^1.65.7",
        "laravel/vapor-core": "^2.41",
        "league/flysystem-aws-s3-v3": "^3.30",
        "mailchimp/marketing": "^3.0",
        "mchev/banhammer": "^2.4",
        "shopify/shopify-api": "^6.0",
        "signifly/laravel-shopify": "^1.2.9",
        "socialiteproviders/mailchimp": "^4.1",
        "socialiteproviders/manager": "^4.4",
        "socialiteproviders/shopify": "^4.2",
        "spatie/laravel-honeypot": "^4.6",
        "spatie/laravel-ignition": "^2.9",
        "spatie/laravel-permission": "^6.23",
        "srmklive/paypal": "^3.0",
        "stevebauman/location": "^7.6",
        "stripe/stripe-php": "^18.0",
        "symfony/http-client": "^7.0",
        "symfony/mailgun-mailer": "^7.0",
        "tightenco/ziggy": "^1.0"
    },
    "require-dev": {
        "laravel/breeze": "^2.3.8",
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.4"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
